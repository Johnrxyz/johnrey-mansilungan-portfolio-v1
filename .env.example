# ── Brevo transactional email (contact form) ──────────────────────────────
# These are read ONLY by the Netlify function (netlify/functions/send-contact.js).
# They are secrets — do NOT prefix with VITE_ and do NOT commit real values.
# Set them in Netlify → Site settings → Environment variables (and locally in a
# .env file if you run `netlify dev`).

# Brevo API v3 key — starts with "xkeysib-"
BREVO_API_KEY=

# A sender address VERIFIED in your Brevo account (Senders, Domains & Dedicated IPs)
BREVO_SENDER_EMAIL=

# Optional — display name shown as the sender
BREVO_SENDER_NAME=Portfolio Contact Form

# Optional — where contact messages are delivered (defaults to your email)
CONTACT_TO_EMAIL=mansilungan.johnrey.dll@gmail.com
